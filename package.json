{
  "name": "tedxguc-hub",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm --prefix frontend run dev\" \"npm --prefix backend run dev\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build": "npm --prefix frontend run build",
    "build:dev": "cd frontend && npm install && npm run build:dev",
    "lint:frontend": "npm --prefix frontend run lint",
    "test:frontend": "npm --prefix frontend run test",
    "typecheck:frontend": "npm --prefix frontend run typecheck",
    "test:backend": "npm --prefix backend run test",
    "db:export": "npm --prefix backend run db:export",
    "db:reset": "npm --prefix backend run db:reset"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  }
}
